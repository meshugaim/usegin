{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://askeffi.ai/schemas/tdd-skills/impl-plan.schema.json",
  "title": "impl-plan.md frontmatter",
  "description": "Schema for the impl-plan.md artefact emitted by the tdd-impl-plan skill. Walked one cycle at a time by tdd-execute.\n\nStructural invariants enforced at runtime by the tdd-execute setup gate (F-SCHEMA-3, dry-run §4):\n  - steps[0].role == 'outer-red'\n  - steps[steps.length - 1].role == 'outer-green'\n  - steps[0].target_test_id == steps[steps.length - 1].target_test_id\n  - that target_test_id resolves to a row in the referenced test-plan with outermost: true\n  - steps[i].n == i + 1 (F-SCHEMA-4)\nPure-schema enforcement of these via prefixItems was judged over-engineered; the setup gate is the canonical check.",
  "type": "object",
  "required": ["test_plan", "spec", "generated_at", "generated_by", "steps"],
  "additionalProperties": false,
  "properties": {
    "test_plan": {
      "type": "string",
      "description": "Relative path to the test-plan.md from test-architecture."
    },
    "spec": {
      "type": "string",
      "pattern": "^ENG-\\d+$",
      "description": "Linear spec issue id."
    },
    "slice": {
      "type": "string",
      "description": "Slice identifier — Linear sub-issue id of the slice this impl-plan belongs to. Optional. When present, tdd-execute uses it to derive the workspace path .tdd-execute/<slice>/. Pattern allows a bare ENG-id (whole-spec slices) or a sub-issue id (ENG-XXXX-N). Must match the test-plan's slice field when both are set (F-COUPLE-4).",
      "pattern": "^ENG-\\d+(-\\d+)?$"
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "generated_by": { "type": "string" },

    "cycle_budgets": {
      "type": "object",
      "description": "Top-level defaults for cycle budgets. Per-step overrides take precedence (F-SCHEMA-5).",
      "additionalProperties": false,
      "properties": {
        "lines_per_green": {
          "type": "integer",
          "minimum": 1,
          "default": 50,
          "description": "Default cap on added/changed lines per Green cycle (excluding imports and whitespace). GreenTweaker reads this when step.line_budget is not set."
        },
        "retry_cap": {
          "type": "integer",
          "minimum": 1,
          "default": 3,
          "description": "Maximum re-spawn attempts per cycle before the Director escalates to the user."
        }
      }
    },

    "pre_red": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "formatter_commits": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["cmd", "rationale"],
            "additionalProperties": false,
            "properties": {
              "cmd": { "type": "string" },
              "rationale": { "type": "string" }
            }
          }
        }
      }
    },

    "walking_skeleton": {
      "type": "object",
      "required": ["required"],
      "additionalProperties": false,
      "properties": {
        "required": { "type": "boolean" },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["description", "target_test_id"],
            "additionalProperties": false,
            "properties": {
              "description": { "type": "string" },
              "target_test_id": { "type": "string", "pattern": "^T\\d+$" }
            }
          }
        }
      },
      "if": { "properties": { "required": { "const": true } } },
      "then": { "required": ["required", "steps"] }
    },

    "steps": {
      "type": "array",
      "minItems": 2,
      "description": "Ordered execution. F-SCHEMA-3 invariants (enforced by tdd-execute setup gate, not by pure schema): steps[0].role == 'outer-red'; steps[last].role == 'outer-green'; both reference the same target_test_id; that target_test_id resolves to a test-plan row with outermost: true.",
      "items": {
        "type": "object",
        "required": ["n", "target_test_id", "layer", "role", "tdd_or_verification"],
        "additionalProperties": false,
        "properties": {
          "n": {
            "type": "integer",
            "minimum": 1,
            "description": "1-based step index. Invariant (F-SCHEMA-4, runtime-enforced by tdd-execute): steps[i].n == i + 1. Pure-schema enforcement via prefixItems was judged over-engineered."
          },
          "target_test_id": { "type": "string", "pattern": "^T\\d+$" },
          "layer": {
            "type": "string",
            "description": "Must stay in sync with test-plan.schema.json#/$defs/layer enum (single source of truth — F-SCHEMA-1).",
            "enum": ["unit", "python-unit", "nextjs-db", "nextjs-browser", "python-db", "python-llm", "code-integration", "e2e", "external", "sql-rls", "e2e-cli-framework"]
          },
          "role": {
            "type": "string",
            "enum": ["outer-red", "inner-red", "inner-green", "inner-refactor", "outer-green", "verification-only", "scaffolding", "contract-check", "mutation-pass"]
          },
          "tdd_or_verification": {
            "type": "object",
            "required": ["tdd"],
            "additionalProperties": false,
            "properties": {
              "tdd": { "type": "boolean" },
              "reason": { "type": "string" }
            },
            "if": { "properties": { "tdd": { "const": false } } },
            "then": { "required": ["tdd", "reason"] }
          },
          "transformation_hint": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "tpp_rank": { "type": "integer", "minimum": 1, "maximum": 11 }
            }
          },
          "predicted_seam_touchpoints": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["file", "kind"],
              "additionalProperties": false,
              "properties": {
                "file": { "type": "string" },
                "kind": { "type": "string", "enum": ["read", "write", "new"] }
              }
            }
          },
          "blocker_dependencies": {
            "type": "array",
            "items": { "type": "integer", "minimum": 1 }
          },
          "deferred_red": { "type": "boolean", "default": false },
          "notes": { "type": "string" }
        }
      }
    },

    "mutation_pass": {
      "type": "object",
      "required": ["required"],
      "additionalProperties": false,
      "properties": {
        "required": { "type": "boolean" },
        "scope": { "type": "string" },
        "mutations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "target_file", "mutation", "expected_to_be_caught_by"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "pattern": "^M\\d+$" },
              "target_file": { "type": "string" },
              "target_function": { "type": "string" },
              "target_line": { "type": "integer" },
              "mutation": { "type": "string" },
              "expected_to_be_caught_by": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "pattern": "^T\\d+$" }
              }
            }
          }
        }
      },
      "if": { "properties": { "required": { "const": true } } },
      "then": { "required": ["required", "scope", "mutations"] }
    }
  }
}
