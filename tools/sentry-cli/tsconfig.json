{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["bun"],
    "paths": {
      "@lib/*": ["../lib/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*", "tests/**/*", "../lib/sentry-api.ts"],
  "exclude": ["../lib/**/*.test.ts"]
}
